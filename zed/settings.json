// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "git_panel": {
    "tree_view": true,
  },
  "languages": {
    "Python": {
      // 1. Explicitly enable both default servers side-by-side
      "language_servers": ["basedpyright", "ruff"],
      // 2. Set up the two-phase Ruff formatting pipeline
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.organizeImports.ruff": true,
      },
      "formatter": {
        "language_server": {
          "name": "ruff",
        },
      },
    },
  },
  "lsp": {
    "basedpyright": {
      "settings": {
        "python": {
          "pythonPath": ".venv/Scripts/python.exe",
        },
        "basedpyright.analysis": {
          "inlayHints": {
            "callArgumentNames": true,
            "functionReturnTypes": true,
            "variableTypes": true,
          },
          // Instructs basedpyright to evaluate your whole workspace instead of just open files
          "diagnosticMode": "workspace",
          // Turns off conflicting lint warnings so Ruff has exclusive control over them
          "reportUnusedImport": "none",
          "reportUnusedVariable": "none",
        },
      },
    },
  },

  "wsl_connections": [
    {
      "distro_name": "Ubuntu-22.04",
      "user": null,
      "projects": [],
    },
  ],
  "cli_default_open_behavior": "existing_window",
  "telemetry": {
    "diagnostics": true,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry",
    },
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "Gruvbox Light",
    "dark": "Gruvbox Dark",
  },
  "buffer_font_family": "JetBrains Mono NL",
  "icon_theme": "Catppuccin Mocha",
  "buffer_font_features": { "calt": true },
  "soft_wrap": "editor_width",
}
